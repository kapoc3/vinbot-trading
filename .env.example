# Binance API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key
USE_TESTNET=True
TRADING_SYMBOLS=BTCUSDT,ETHUSDT

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
LOG_LEVEL=INFO

# FastAPI Settings
PROJECT_NAME="VinBot Trading Core"
API_V1_STR="/api/v1"
# Trading Logic
# Options: RsiOnly, RsiWithDivergence, BollingerBands, MacdMaCross, Breakout, Auto
TRADING_STRATEGY=Auto

# Risk Management
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_LOSS_PCT=2.0

# Partial Take Profit (Scaled Exits)
# Format: "profit_target:percent_to_sell,..."
PARTIAL_TP_LEVELS="5.0:50,10.0:25"
MOVE_SL_TO_BE_ON_TP1=True

# Dynamic Position Sizing (Risk-Based)
ENABLE_DYNAMIC_SIZING=True
ALLOCATED_CAPITAL=1000.0
RISK_PER_TRADE_PCT=1.0

# Global Filters (Veto Layer)
ENABLE_VOLUME_CONFIRMATION=True
ENABLE_TRAILING_STOP=True
ENABLE_BTC_DIRECTIONAL_FILTER=True
BTC_DIRECTION_EMA=200
ENABLE_RELATIVE_STRENGTH_FILTER=True
RS_LOOKBACK_PERIOD=14
